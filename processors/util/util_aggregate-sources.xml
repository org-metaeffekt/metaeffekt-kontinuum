  <parent>
    <groupId>com.metaeffekt.kontinuum</groupId>
    <artifactId>ae-kontinuum-processors</artifactId>
    <version>KONTINUUM-SNAPSHOT</version>
    <relativePath>../_common_/ae-kontinuum-processors.xml</relativePath>
  </parent>

  <artifactId>util_aggregate-sources</artifactId>

  <build>
    <plugins>
      <plugin>
        <groupId>org.metaeffekt.core</groupId>
        <artifactId>ae-inventory-maven-plugin</artifactId>
        <version>${ae.core.version}</version>

        <executions>
          <execution>
            <id>aggregate</id>
            <goals>
              <goal>aggregate-sources</goal>
            </goals>
            <phase>validate</phase>
            <configuration>
              <includeAllSources>${param.include.all.sources}</includeAllSources>
              <failOnMissingSources>${param.fail.on.missing.sources}</failOnMissingSources>
              <inventoryPath>${input.inventory.file}</inventoryPath>

              <!-- Source Repositories -->
              <sourceRepositories>

                <sourceRepository>
                  <id>Public FileServer Mirrors</id>
                  <targetFolder>${output.artifacts.dir}</targetFolder>
                  <patterns>
                    <pattern>^.*\.jar</pattern>
                  </patterns>
                  <fileServerMirror>
                    <propertyFilePath>${param.property.file}</propertyFilePath>
                    <sourceUrls>
                      <url>https://$[host02]/maven2/$[artifact.groupId]/$[artifact.groupId]/$[artifact.version]/$[artifact.name]</url>
                    </sourceUrls>
                  </fileServerMirror>
                </sourceRepository>

                <sourceRepository>
                  <id>Internal / External Eclipse Mirrors</id>
                  <targetFolder>${output.artifacts.dir}</targetFolder>
                  <patterns>
                    <!-- patterns: "artifact:component:version:effectiveLicense"; Regular expressions start with '^' -->
                    <pattern>^org\.eclipse\..*_.*\.jar:^.*:^.*:^.*</pattern>
                  </patterns>
                  <eclipseMirror>
                    <mirrorUrls>
                      <url>https://builds.gradle.org:8001/eclipse/update-site/mirror/releases-rolling/features/</url>
                    </mirrorUrls>
                  </eclipseMirror>
                </sourceRepository>

                <sourceRepository>
                  <id>Internal / External Eclipse Mirrors</id>
                  <targetFolder>${output.artifacts.dir}</targetFolder>
                  <patterns>
                    <!-- patterns: "artifact:component:version:effectiveLicense"; Regular expressions start with '^' -->
                    <pattern>^.*?_.*\.jar</pattern>
                  </patterns>
                  <eclipseMirror>
                    <mirrorUrls>
                      <url>https://builds.gradle.org:8001/eclipse/update-site/mirror/releases-rolling/plugins/</url>
                    </mirrorUrls>
                  </eclipseMirror>
                </sourceRepository>

                <sourceRepository>
                  <id>Maven Repo (Mapped)</id>

                  <!-- this variant shows how incomplete artifacts can be mapped to a maven repository -->

                  <targetFolder>${output.artifacts.dir}</targetFolder>
                  <patterns>
                    <pattern>^.*\.jar</pattern>
                  </patterns>
                  <componentMirror>
                    <mappings>
                      <map>^Bouncy Castle-.*:org/bouncycastle/$artifactId/$version/$artifactId-$version-sources.$type</map>
                      <map>^bcpkix-jdk18on-([0-9]*\.[0-9]*).jar:org/bouncycastle/bcpkix-jdk18on/$1/bcpkix-jdk18on-$1-sources.jar</map>
                    </mappings>
                    <mirrorUrls>
                      <url>https://repo1.maven.org/maven2/</url>
                    </mirrorUrls>
                  </componentMirror>
                </sourceRepository>

                <sourceRepository>

                  <!-- this variant shows how arbitrary (yet complete gav) artifacts can be mapped -->

                  <id>Maven Repo (Fallback)</id>
                  <targetFolder>${output.artifacts.dir}</targetFolder>
                  <patterns>
                    <pattern>^.*\.jar</pattern>
                  </patterns>
                  <mavenMirror />
                </sourceRepository>

              </sourceRepositories>
            </configuration>

          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
